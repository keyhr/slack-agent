# SearXNG シークレットキー（ランダムな文字列を設定すること）
# 生成例: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SEARXNG_SECRET_KEY=

SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

OPENROUTER_API_KEY=sk-or-...

# カンマ区切りでSlack管理者のユーザーIDを列挙
# SlackのユーザーIDは「プロフィール → ... → メンバーIDをコピー」で確認
ADMIN_USER_IDS=U012ABC3DEF,U012XYZ7GHI

# SQLiteファイルパス（Dockerボリューム内）
DB_PATH=/app/data/bot.db

# デイリーニュースダイジェスト設定
# 投稿先チャンネルID（必須。例: C0123456789）
NEWS_CHANNEL_ID=

# メンションするユーザーIDをカンマ区切りで（省略可）
NEWS_MENTION_USER_IDS=

# ニュース取得に使うモデル（省略時はDEFAULT_MODELを使用）
NEWS_MODEL=

# 配信時刻（デフォルト: JST 6:00）
NEWS_CRON_HOUR=6
NEWS_CRON_MINUTE=0
NEWS_CRON_TZ=Asia/Tokyo
